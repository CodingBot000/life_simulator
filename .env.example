NODE_ENV=development
PORT=3000

POSTGRES_DB=life_simulator_dev
POSTGRES_USER=life_sim_user
POSTGRES_PASSWORD=life_sim_password
POSTGRES_PORT=5433
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

DATABASE_URL=postgresql://life_sim_user:life_sim_password@db:5432/life_simulator_dev

LLM_PROVIDER_MODE=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
LOW_COST_MODEL=gpt-5-mini
PREMIUM_MODEL=gpt-5
LOW_COST_FALLBACK_MODEL=gpt-5-mini
PREMIUM_FALLBACK_MODEL=gpt-5-mini

REQUEST_DEADLINE_MS=25000
LLM_CACHE_TTL_MS=300000
LLMOPS_INLINE_QUEUE_DRAIN=false
REQUIRE_SIM_AUTH=false
LLMOPS_RATE_LIMIT_COUNT=30
LLMOPS_RATE_LIMIT_WINDOW_MS=60000
DRIFT_BUCKET_HOURS=24
EVAL_WORKER_LIMIT=10
