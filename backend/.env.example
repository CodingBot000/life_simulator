SIMULATOR_LLM_PROVIDER=codex

# Codex mode
SIMULATOR_CODEX_COMMAND=codex
SIMULATOR_CODEX_MODEL=gpt-5.3-codex-spark
SIMULATOR_CODEX_TIMEOUT=75s
SIMULATOR_CODEX_FALLBACK_ON_ERROR=false

# OpenAI API mode
OPENAI_API_KEY=
SIMULATOR_OPENAI_MODEL=gpt-5.3
SIMULATOR_OPENAI_TIMEOUT=75s
SIMULATOR_OPENAI_FALLBACK_ON_ERROR=false

# Mock mode
SIMULATOR_MOCK_MODEL=spring-mock

# Optional database
BACKEND_DATABASE_ENABLED=false
BACKEND_DATABASE_URL=jdbc:postgresql://localhost:5432/life_simulator_dev
BACKEND_DATABASE_USERNAME=life_sim_user
BACKEND_DATABASE_PASSWORD=life_sim_password

# Recommendations MVP
SIMULATOR_RECOMMENDATIONS_ENABLED=true
SIMULATOR_RECOMMENDATIONS_LLM_INTENT_ENABLED=false
SIMULATOR_RECOMMENDATIONS_DEFAULT_MAX_ITEMS=6
SIMULATOR_RECOMMENDATIONS_MAX_ITEMS=12
SIMULATOR_RECOMMENDATIONS_DEFAULT_PROVIDERS=catalog

# Optional Naver Search recommendation provider
# Do not commit real values. Enable with DEFAULT_PROVIDERS=catalog,naver.
SIMULATOR_RECOMMENDATIONS_NAVER_ENABLED=false
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
SIMULATOR_RECOMMENDATIONS_NAVER_TIMEOUT=3s
SIMULATOR_RECOMMENDATIONS_NAVER_DISPLAY=3
SIMULATOR_RECOMMENDATIONS_NAVER_MAX_QUERIES=2
SIMULATOR_RECOMMENDATIONS_NAVER_SHOPPING_ENABLED=true

# Optional YouTube known-video recommendation provider
# No API key is required. Enable with DEFAULT_PROVIDERS=catalog,youtube.
SIMULATOR_RECOMMENDATIONS_YOUTUBE_ENABLED=false
SIMULATOR_RECOMMENDATIONS_YOUTUBE_TIMEOUT=3s
SIMULATOR_RECOMMENDATIONS_YOUTUBE_MAX_ITEMS=2
SIMULATOR_RECOMMENDATIONS_YOUTUBE_SEED_RESOURCE=/recommendations/youtube.videos.ko.json
