{
  "name": "life-simulator",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -p tsconfig.app.json --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "vite preview --host 0.0.0.0",
    "typecheck": "npm run typecheck:app && npm run typecheck:legacy",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:legacy": "tsc -p tsconfig.legacy.json --noEmit",
    "worker:log": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types workers/log-worker/index.ts",
    "worker:drift": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types workers/drift-worker/index.ts",
    "worker:eval": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types workers/eval-worker/index.ts",
    "eval:guardrail": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/eval_guardrail.ts",
    "eval:guardrail-calibration": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/eval_guardrail_calibration.ts",
    "eval:guardrail-thresholds": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/eval_guardrail_thresholds.ts",
    "relabel:guardrail-datasets": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/relabel_guardrail_datasets.ts",
    "optimize:guardrail": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/optimize_guardrail_thresholds.ts",
    "re-eval:online-anomalies": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/re_eval_online_anomalies.ts",
    "run:simulate": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/run-simulate.ts",
    "seed:anomalies": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/seed-anomalies.ts",
    "seed:reeval": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/seed-reeval.ts",
    "run:reeval": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/run-reeval.ts",
    "verify:monitoring": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/verify-monitoring.ts",
    "analyze:reeval": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/analyze-reeval-mismatches.ts",
    "compare:guardrail-adjustment": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/compare-guardrail-adjustment.ts",
    "analyze:review-overtrigger": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/analyze-review-overtrigger.ts",
    "analyze:baseline-v4": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/analyze-baseline-v4.ts",
    "analyze:baseline-v5": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/analyze-baseline-v5.ts",
    "analyze:baseline-v6": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/analyze-baseline-v6.ts",
    "analyze:baseline-v7": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/analyze-baseline-v7.ts",
    "analyze:baseline-v8": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/analyze-baseline-v8.ts"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "openai": "6.32.0",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "postcss": "8.5.8",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite": "^8.0.10"
  }
}
