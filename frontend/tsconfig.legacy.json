{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "esnext"
    ],
    "types": [
      "node"
    ],
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.legacy.tsbuildinfo"
  },
  "include": [
    "scripts/**/*.ts",
    "workers/**/*.ts",
    "src/config/**/*.ts",
    "src/guardrail/**/*.ts",
    "src/lib/**/*.ts",
    "src/server/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/lib/api/**"
  ]
}
