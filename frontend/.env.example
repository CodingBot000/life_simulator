NODE_ENV=development
PORT=3000

POSTGRES_DB=life_simulator_dev
POSTGRES_USER=life_sim_user
POSTGRES_PASSWORD=life_sim_password
POSTGRES_PORT=5433
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

DATABASE_URL=postgresql://life_sim_user:life_sim_password@db:5432/life_simulator_dev

NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

LLM_PROVIDER_MODE=codex
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.3-codex-spark
LOW_COST_MODEL=gpt-5.3-codex-spark
PREMIUM_MODEL=gpt-5.3-codex-spark
LOW_COST_FALLBACK_MODEL=gpt-5.3-codex-spark
PREMIUM_FALLBACK_MODEL=gpt-5.3-codex-spark

REQUEST_DEADLINE_MS=15000
LLM_CACHE_TTL_MS=300000
LLMOPS_INLINE_QUEUE_DRAIN=false
REQUIRE_SIM_AUTH=false
LLMOPS_RATE_LIMIT_COUNT=30
LLMOPS_RATE_LIMIT_WINDOW_MS=60000
DRIFT_BUCKET_HOURS=24
EVAL_WORKER_LIMIT=10
